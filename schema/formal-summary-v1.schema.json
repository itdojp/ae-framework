{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/formal-summary-v1.schema.json",
  "title": "Formal Summary v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "tool",
    "artifactStatus",
    "producer",
    "status",
    "ok",
    "generatedAtUtc",
    "metadata",
    "results"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "formal-summary/v1",
      "description": "Schema identifier for Formal Summary v1."
    },
    "tool": {
      "type": "string",
      "description": "Tool identifier for this summary (or aggregate).",
      "enum": [
        "tla",
        "apalache",
        "smt",
        "alloy",
        "conformance",
        "kani",
        "spin",
        "csp",
        "lean",
        "model",
        "aggregate"
      ]
    },
    "status": {
      "type": "string",
      "description": "High-level status for this summary.",
      "enum": [
        "ok",
        "failed",
        "skipped",
        "missing",
        "unknown",
        "timeout",
        "tool-error"
      ]
    },
    "ok": {
      "type": "boolean",
      "description": "True only when all results are ok."
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time",
      "description": "When this summary was generated (UTC ISO8601)."
    },
    "metadata": {
      "$ref": "https://ae-framework/schema/artifact-metadata.schema.json"
    },
    "results": {
      "type": "array",
      "description": "Normalized result items (even for single-task tools).",
      "items": {
        "$ref": "#/$defs/resultItem"
      }
    },
    "artifactStatus": {
      "const": "execution-report"
    },
    "producer": {
      "$ref": "#/$defs/summaryProducer"
    }
  },
  "$defs": {
    "resultItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "artifactStatus",
        "code",
        "durationMs",
        "logPath",
        "reason"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "failed",
            "skipped",
            "missing",
            "unknown",
            "timeout",
            "tool-error"
          ]
        },
        "code": {
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "durationMs": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "logPath": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "reason": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "executionEvidence": {
          "$ref": "https://ae-framework/schema/formal-execution-evidence-v1.schema.json"
        },
        "artifactStatus": {
          "enum": [
            "execution-report",
            "not-executed"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "executionEvidence"
            ]
          },
          "then": {
            "properties": {
              "executionEvidence": {
                "properties": {
                  "provenance": {
                    "const": "adapter-verified"
                  }
                },
                "required": [
                  "provenance",
                  "adapter"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "artifactStatus": {
                "const": "execution-report"
              }
            },
            "required": [
              "artifactStatus"
            ]
          },
          "then": {
            "required": [
              "executionEvidence"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "ok"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "artifactStatus": {
                "const": "execution-report"
              },
              "executionEvidence": {
                "properties": {
                  "executionOccurred": {
                    "const": true
                  },
                  "artifactStatus": {
                    "const": "execution-report"
                  },
                  "result": {
                    "properties": {
                      "status": {
                        "const": "ok"
                      },
                      "code": {
                        "const": 0
                      }
                    },
                    "required": [
                      "status"
                    ]
                  },
                  "tool": {
                    "properties": {
                      "versionStatus": {
                        "const": "verified"
                      },
                      "version": {
                        "not": {
                          "enum": [
                            "",
                            "unknown",
                            "unspecified",
                            "n/a",
                            "na",
                            "none",
                            "null"
                          ]
                        }
                      }
                    },
                    "required": [
                      "version",
                      "versionStatus"
                    ]
                  }
                },
                "required": [
                  "executionOccurred",
                  "artifactStatus",
                  "result",
                  "tool"
                ]
              }
            },
            "required": [
              "executionEvidence"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "failed"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "artifactStatus": {
                "const": "execution-report"
              },
              "executionEvidence": {
                "properties": {
                  "executionOccurred": {
                    "const": true
                  },
                  "artifactStatus": {
                    "const": "execution-report"
                  },
                  "result": {
                    "properties": {
                      "status": {
                        "const": "failed"
                      }
                    },
                    "required": [
                      "status"
                    ]
                  }
                },
                "required": [
                  "executionOccurred",
                  "artifactStatus",
                  "result"
                ]
              }
            },
            "required": [
              "executionEvidence"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "timeout"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "artifactStatus": {
                "const": "execution-report"
              },
              "executionEvidence": {
                "properties": {
                  "executionOccurred": {
                    "const": true
                  },
                  "artifactStatus": {
                    "const": "execution-report"
                  },
                  "result": {
                    "properties": {
                      "status": {
                        "const": "timeout"
                      }
                    },
                    "required": [
                      "status"
                    ]
                  }
                },
                "required": [
                  "executionOccurred",
                  "artifactStatus",
                  "result"
                ]
              }
            },
            "required": [
              "executionEvidence"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "tool-error"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "artifactStatus": {
                "const": "execution-report"
              },
              "executionEvidence": {
                "properties": {
                  "executionOccurred": {
                    "const": true
                  },
                  "artifactStatus": {
                    "const": "execution-report"
                  },
                  "result": {
                    "properties": {
                      "status": {
                        "const": "tool-error"
                      }
                    },
                    "required": [
                      "status"
                    ]
                  }
                },
                "required": [
                  "executionOccurred",
                  "artifactStatus",
                  "result"
                ]
              }
            },
            "required": [
              "executionEvidence"
            ]
          }
        }
      ]
    },
    "summaryProducer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "contract",
        "artifactRef"
      ],
      "properties": {
        "id": {
          "const": "ae.formal.summary-generator"
        },
        "version": {
          "const": "1.0.0"
        },
        "contract": {
          "const": "formal-summary-adapter/v1"
        },
        "artifactRef": {
          "const": "scripts/formal/generate-formal-summary-v1.mjs"
        }
      }
    }
  }
}
