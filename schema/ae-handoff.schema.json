{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/ae-handoff.schema.json",
  "title": "AE-HANDOFF",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "goal",
    "currentStatus",
    "nextActions",
    "commandsRun",
    "artifacts",
    "risksRollbackNote",
    "blockers",
    "changePackageRef"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "ae-handoff/v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "handoffTarget": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "currentStatus": {
      "type": "string",
      "minLength": 1
    },
    "nextActions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nextAction"
      }
    },
    "commandsRun": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "risksRollbackNote": {
      "type": [
        "string",
        "null"
      ]
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/blocker"
      }
    },
    "changePackageRef": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "$defs": {
    "nextAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "order",
        "summary"
      ],
      "properties": {
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "human",
            "ci",
            "external",
            "unknown"
          ]
        }
      }
    }
  }
}
