{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/execution-plan-v1.schema.json",
  "title": "ae-execution-plan-v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "contractId": {
      "type": "string",
      "const": "execution-plan.v1"
    },
    "planId": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 }
      },
      "required": ["owner", "name"]
    },
    "pullRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "headSha": { "type": "string", "minLength": 7 }
      },
      "required": ["number", "headSha"]
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "review_feedback",
            "manual_dispatch",
            "schedule",
            "gate_retry",
            "autopilot"
          ]
        },
        "source": { "type": "string", "minLength": 1 },
        "at": { "type": "string", "format": "date-time" }
      },
      "required": ["kind", "source", "at"]
    },
    "targetState": {
      "type": "string",
      "enum": [
        "review_feedback_pending",
        "action_execution",
        "gate_recheck",
        "merge_eligible",
        "blocked"
      ]
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": {
            "type": "string",
            "enum": [
              "review_fetch",
              "suggestion_apply",
              "workflow_dispatch",
              "gate_recheck",
              "label_sync",
              "artifact_collect",
              "comment_emit",
              "block_emit"
            ]
          },
          "title": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "enum": ["ai", "human", "either"] },
          "dependsOn": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "run": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "command": { "type": "string", "minLength": 1 },
              "workflow": { "type": "string", "minLength": 1 },
              "args": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "conditions": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "requiresLabels": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "forbiddenLabels": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "maxAttempts": { "type": "integer", "minimum": 1 },
              "stopOnFailure": { "type": "boolean" }
            }
          },
          "expectedArtifacts": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "status": {
            "type": "string",
            "enum": ["planned", "running", "completed", "failed", "skipped"]
          },
          "result": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "status": {
                "type": "string",
                "enum": ["success", "failure", "skipped"]
              },
              "summaryPath": { "type": "string", "minLength": 1 },
              "message": { "type": "string" }
            },
            "required": ["status"]
          }
        },
        "required": ["id", "kind", "title", "owner", "status"]
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runId": { "type": "string", "minLength": 1 },
        "workflow": { "type": "string", "minLength": 1 },
        "generatedAt": { "type": "string", "format": "date-time" },
        "generator": { "type": "string", "minLength": 1 }
      },
      "required": ["runId", "workflow", "generatedAt", "generator"]
    }
  },
  "required": [
    "schemaVersion",
    "contractId",
    "planId",
    "repository",
    "pullRequest",
    "trigger",
    "targetState",
    "tasks",
    "metadata"
  ]
}
