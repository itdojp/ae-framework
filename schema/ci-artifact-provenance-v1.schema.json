{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/ci-artifact-provenance-v1.schema.json",
  "title": "CI Artifact Provenance v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "artifact",
    "producer"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ci-artifact-provenance/v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "subjects"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "subjects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path",
              "sha256",
              "size"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "size": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "workflow",
        "workflowRef",
        "runId",
        "runAttempt",
        "eventName",
        "headSha",
        "baseSha",
        "prNumber",
        "headRepository",
        "baseRepository"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^/\\s]+/[^/\\s]+$"
        },
        "workflow": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "workflowRef": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "runId": {
          "type": "string",
          "pattern": "^[1-9][0-9]*$"
        },
        "runAttempt": {
          "type": "string",
          "pattern": "^[1-9][0-9]*$"
        },
        "eventName": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+$"
        },
        "headSha": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{40}$"
        },
        "baseSha": {
          "type": "string",
          "pattern": "^$|^[0-9a-fA-F]{40}$"
        },
        "prNumber": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "headRepository": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^/\\s]+/[^/\\s]+$"
        },
        "baseRepository": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^/\\s]+/[^/\\s]+$"
        }
      }
    }
  }
}
