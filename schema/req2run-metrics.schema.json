{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/req2run-metrics.schema.json",
  "title": "req2run-metrics/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reportOnly",
    "generatedAt",
    "source",
    "subject",
    "privacy",
    "collectionBoundaries",
    "sourceArtifacts",
    "metrics",
    "limitations",
    "summary"
  ],
  "properties": {
    "schemaVersion": { "const": "req2run-metrics/v1" },
    "reportOnly": { "const": true },
    "generatedAt": { "type": "string", "format": "date-time" },
    "source": { "$ref": "#/$defs/nonEmptyString" },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "referenceFlow"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "requirementRef": { "type": ["string", "null"] },
        "referenceFlow": { "$ref": "#/$defs/nonEmptyString" },
        "repository": { "type": ["string", "null"] }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rawTextIncluded", "publicRawLogsAllowed", "publicationStatus", "redactionMode"],
      "properties": {
        "rawTextIncluded": { "type": "boolean" },
        "publicRawLogsAllowed": { "type": "boolean" },
        "publicationStatus": { "$ref": "#/$defs/nonEmptyString" },
        "redactionMode": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "collectionBoundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflowEvaluated", "externalAgentApisCalled", "agentVendorComparison", "approvalAuthority", "reportOnlyReason"],
      "properties": {
        "workflowEvaluated": { "$ref": "#/$defs/nonEmptyString" },
        "externalAgentApisCalled": { "const": false },
        "agentVendorComparison": { "const": false },
        "approvalAuthority": { "$ref": "#/$defs/nonEmptyString" },
        "reportOnlyReason": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "sourceArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceArtifact" }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "time_to_first_runnable_verification_minutes",
        "spec_task_evidence_coverage",
        "deterministic_replay_pass_rate",
        "manual_intervention_count",
        "evidence_review_completeness"
      ],
      "properties": {
        "time_to_first_runnable_verification_minutes": { "$ref": "#/$defs/durationMetric" },
        "spec_task_evidence_coverage": { "$ref": "#/$defs/ratioMetric" },
        "deterministic_replay_pass_rate": { "$ref": "#/$defs/ratioMetric" },
        "manual_intervention_count": { "$ref": "#/$defs/countMetric" },
        "evidence_review_completeness": { "$ref": "#/$defs/ratioMetric" }
      }
    },
    "limitations": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "summary": { "$ref": "#/$defs/nonEmptyString" }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "nonNegativeInteger": { "type": "integer", "minimum": 0 },
    "sourceArtifactRefs": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "metricCommon": {
      "type": "object",
      "required": ["reviewerQuestion", "calculationMethod", "interpretation", "limitation", "sourceArtifactRefs"],
      "properties": {
        "reviewerQuestion": { "$ref": "#/$defs/nonEmptyString" },
        "calculationMethod": { "$ref": "#/$defs/nonEmptyString" },
        "interpretation": { "$ref": "#/$defs/nonEmptyString" },
        "limitation": { "$ref": "#/$defs/nonEmptyString" },
        "sourceArtifactRefs": { "$ref": "#/$defs/sourceArtifactRefs" }
      }
    },
    "collectibleNumber": {
      "oneOf": [
        { "type": "number", "minimum": 0 },
        { "enum": ["not_collected"] }
      ]
    },
    "ratioOrNull": {
      "oneOf": [
        { "type": "number", "minimum": 0, "maximum": 1 },
        { "type": "null" }
      ]
    },
    "durationMetric": {
      "allOf": [
        { "$ref": "#/$defs/metricCommon" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["value", "unit", "from", "to", "reviewerQuestion", "calculationMethod", "interpretation", "limitation", "sourceArtifactRefs"],
          "properties": {
            "value": { "$ref": "#/$defs/collectibleNumber" },
            "unit": { "const": "minutes" },
            "from": { "type": ["string", "null"], "format": "date-time" },
            "to": { "type": ["string", "null"], "format": "date-time" },
            "reviewerQuestion": { "$ref": "#/$defs/nonEmptyString" },
            "calculationMethod": { "$ref": "#/$defs/nonEmptyString" },
            "interpretation": { "$ref": "#/$defs/nonEmptyString" },
            "limitation": { "$ref": "#/$defs/nonEmptyString" },
            "sourceArtifactRefs": { "$ref": "#/$defs/sourceArtifactRefs" }
          }
        }
      ]
    },
    "ratioMetric": {
      "allOf": [
        { "$ref": "#/$defs/metricCommon" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["numerator", "denominator", "ratio", "reviewerQuestion", "calculationMethod", "interpretation", "limitation", "sourceArtifactRefs"],
          "properties": {
            "numerator": { "$ref": "#/$defs/nonNegativeInteger" },
            "denominator": { "$ref": "#/$defs/nonNegativeInteger" },
            "ratio": { "$ref": "#/$defs/ratioOrNull" },
            "missingTaskIds": {
              "type": "array",
              "items": { "$ref": "#/$defs/nonEmptyString" }
            },
            "failedAttemptIds": {
              "type": "array",
              "items": { "$ref": "#/$defs/nonEmptyString" }
            },
            "missingEvidenceIds": {
              "type": "array",
              "items": { "$ref": "#/$defs/nonEmptyString" }
            },
            "reviewerQuestion": { "$ref": "#/$defs/nonEmptyString" },
            "calculationMethod": { "$ref": "#/$defs/nonEmptyString" },
            "interpretation": { "$ref": "#/$defs/nonEmptyString" },
            "limitation": { "$ref": "#/$defs/nonEmptyString" },
            "sourceArtifactRefs": { "$ref": "#/$defs/sourceArtifactRefs" }
          }
        }
      ]
    },
    "countMetric": {
      "allOf": [
        { "$ref": "#/$defs/metricCommon" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["count", "reviewerQuestion", "calculationMethod", "interpretation", "limitation", "sourceArtifactRefs"],
          "properties": {
            "count": { "$ref": "#/$defs/nonNegativeInteger" },
            "interventionIds": {
              "type": "array",
              "items": { "$ref": "#/$defs/nonEmptyString" }
            },
            "reviewerQuestion": { "$ref": "#/$defs/nonEmptyString" },
            "calculationMethod": { "$ref": "#/$defs/nonEmptyString" },
            "interpretation": { "$ref": "#/$defs/nonEmptyString" },
            "limitation": { "$ref": "#/$defs/nonEmptyString" },
            "sourceArtifactRefs": { "$ref": "#/$defs/sourceArtifactRefs" }
          }
        }
      ]
    },
    "sourceArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "path", "present", "required", "schemaVersion", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "kind": { "$ref": "#/$defs/nonEmptyString" },
        "path": { "type": ["string", "null"] },
        "present": { "type": "boolean" },
        "required": { "type": "boolean" },
        "schemaVersion": { "type": ["string", "null"] },
        "description": { "type": "string" }
      }
    }
  }
}
