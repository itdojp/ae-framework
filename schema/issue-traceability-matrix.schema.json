{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/issue-traceability-matrix.schema.json",
  "title": "Issue Traceability Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "sourceMap",
    "summary",
    "rows"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "issue-traceability-matrix/v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceMap": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalRequirements",
        "linkedRequirements",
        "unlinkedRequirements",
        "coverage"
      ],
      "properties": {
        "totalRequirements": {
          "type": "integer",
          "minimum": 0
        },
        "linkedRequirements": {
          "type": "integer",
          "minimum": 0
        },
        "unlinkedRequirements": {
          "type": "integer",
          "minimum": 0
        },
        "coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "contextPackDiagramIds": {
          "type": "integer",
          "minimum": 0
        },
        "contextPackMorphismIds": {
          "type": "integer",
          "minimum": 0
        },
        "contextPackAcceptanceTestIds": {
          "type": "integer",
          "minimum": 0
        },
        "missingDiagramLinks": {
          "type": "integer",
          "minimum": 0
        },
        "missingMorphismLinks": {
          "type": "integer",
          "minimum": 0
        },
        "missingAcceptanceTestLinks": {
          "type": "integer",
          "minimum": 0
        },
        "rowsMissingContextPackLinks": {
          "type": "integer",
          "minimum": 0
        },
        "discoveryGoalIds": {
          "type": "integer",
          "minimum": 0
        },
        "discoveryRequirementIds": {
          "type": "integer",
          "minimum": 0
        },
        "discoveryBusinessUseCaseIds": {
          "type": "integer",
          "minimum": 0
        },
        "discoveryDecisionIds": {
          "type": "integer",
          "minimum": 0
        },
        "mappedDiscoveryGoalIds": {
          "type": "integer",
          "minimum": 0
        },
        "mappedDiscoveryRequirementIds": {
          "type": "integer",
          "minimum": 0
        },
        "mappedDiscoveryBusinessUseCaseIds": {
          "type": "integer",
          "minimum": 0
        },
        "mappedDiscoveryDecisionIds": {
          "type": "integer",
          "minimum": 0
        },
        "unmappedApprovedDiscoveryRequirements": {
          "type": "integer",
          "minimum": 0
        },
        "unmappedApprovedDiscoveryBusinessUseCases": {
          "type": "integer",
          "minimum": 0
        },
        "unresolvedDiscoveryGoalRefs": {
          "type": "integer",
          "minimum": 0
        },
        "unresolvedDiscoveryRequirementRefs": {
          "type": "integer",
          "minimum": 0
        },
        "unresolvedDiscoveryBusinessUseCaseRefs": {
          "type": "integer",
          "minimum": 0
        },
        "unresolvedDiscoveryDecisionRefs": {
          "type": "integer",
          "minimum": 0
        },
        "morphismsMissingUpstreamRefs": {
          "type": "integer",
          "minimum": 0
        },
        "acceptanceTestsMissingUpstreamRefs": {
          "type": "integer",
          "minimum": 0
        },
        "diagramsMissingUpstreamRefs": {
          "type": "integer",
          "minimum": 0
        },
        "rowsMissingDiscoveryLinks": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "requirementId",
          "tests",
          "code",
          "linked"
        ],
        "properties": {
          "requirementId": {
            "type": "string",
            "minLength": 1
          },
          "tests": {
            "type": "array",
            "items": { "type": "string" }
          },
          "code": {
            "type": "array",
            "items": { "type": "string" }
          },
          "diagramId": {
            "type": "array",
            "items": { "type": "string" }
          },
          "morphismId": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acceptanceTestId": {
            "type": "array",
            "items": { "type": "string" }
          },
          "discoveryGoalIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "discoveryRequirementIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "discoveryBusinessUseCaseIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "discoveryDecisionIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "linked": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
