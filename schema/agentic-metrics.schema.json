{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/agentic-metrics.schema.json",
  "title": "ae-agentic-metrics",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "tokens": {
      "type": "object",
      "properties": {
        "prompt": { "type": ["integer", "null"], "minimum": 0 },
        "completion": { "type": ["integer", "null"], "minimum": 0 },
        "tool": { "type": ["integer", "null"], "minimum": 0 },
        "total": { "type": ["integer", "null"], "minimum": 0 }
      },
      "additionalProperties": true
    },
    "costUsd": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "memoryHitRatio": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "turns": {
      "type": "object",
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "avgLen": { "type": "number", "minimum": 0 }
      },
      "required": ["count", "avgLen"],
      "additionalProperties": true
    },
    "latencyMs": {
      "type": "integer",
      "minimum": 0
    },
    "agentPrAssurance": {
      "$ref": "#/$defs/agentPrAssurance"
    }
  },
  "required": ["schemaVersion", "turns", "latencyMs"],
  "additionalProperties": true,
  "$defs": {
    "nonNegativeInteger": { "type": "integer", "minimum": 0 },
    "nonNegativeNumber": { "type": "number", "minimum": 0 },
    "ratioOrNull": {
      "oneOf": [
        { "type": "number", "minimum": 0, "maximum": 1 },
        { "type": "null" }
      ]
    },
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "stringArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "artifactArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "coverageMetric": {
      "type": "object",
      "additionalProperties": true,
      "required": ["numerator", "denominator", "ratio"],
      "properties": {
        "numerator": { "$ref": "#/$defs/nonNegativeInteger" },
        "denominator": { "$ref": "#/$defs/nonNegativeInteger" },
        "ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "inputArtifacts": { "$ref": "#/$defs/artifactArray" }
      }
    },
    "countMetric": {
      "type": "object",
      "additionalProperties": true,
      "required": ["count"],
      "properties": {
        "count": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "inputArtifacts": { "$ref": "#/$defs/artifactArray" }
      }
    },
    "waiverCountMetric": {
      "type": "object",
      "additionalProperties": true,
      "required": ["active"],
      "properties": {
        "active": { "$ref": "#/$defs/nonNegativeInteger" },
        "inputArtifacts": { "$ref": "#/$defs/artifactArray" }
      }
    },
    "waiverExpiryRiskMetric": {
      "type": "object",
      "additionalProperties": true,
      "required": ["expired", "expiringSoon"],
      "properties": {
        "expired": { "$ref": "#/$defs/nonNegativeInteger" },
        "expiringSoon": { "$ref": "#/$defs/nonNegativeInteger" },
        "windowDays": { "type": "integer", "minimum": 1 }
      }
    },
    "laneComplianceMetric": {
      "type": "object",
      "additionalProperties": true,
      "required": ["satisfied", "required", "ratio"],
      "properties": {
        "satisfied": { "$ref": "#/$defs/nonNegativeInteger" },
        "required": { "$ref": "#/$defs/nonNegativeInteger" },
        "ratio": { "$ref": "#/$defs/ratioOrNull" },
        "missingLanes": { "$ref": "#/$defs/stringArray" },
        "notApplicable": { "type": "boolean" }
      }
    },
    "evidenceCompletenessMetric": {
      "type": "object",
      "additionalProperties": true,
      "required": ["present", "required", "ratio"],
      "properties": {
        "present": { "$ref": "#/$defs/nonNegativeInteger" },
        "required": { "$ref": "#/$defs/nonNegativeInteger" },
        "ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "missingArtifacts": { "$ref": "#/$defs/artifactArray" }
      }
    },
    "agentRegressionSignalMetric": {
      "type": "object",
      "additionalProperties": true,
      "required": ["currentFailures", "staleOrSupersededFailures", "regressed"],
      "properties": {
        "currentFailures": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "staleOrSupersededFailures": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "operationalNotes": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "currentRequiredFailures": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "policySemanticFailures": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "manualRerunRequired": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "classificationSource": { "$ref": "#/$defs/nonEmptyString" },
        "regressed": { "type": "boolean" }
      }
    },
    "mttrMetric": {
      "type": "object",
      "additionalProperties": true,
      "required": ["minutes"],
      "properties": {
        "minutes": {
          "oneOf": [
            { "$ref": "#/$defs/nonNegativeNumber" },
            { "type": "null" }
          ]
        },
        "from": { "$ref": "#/$defs/nonEmptyString" },
        "to": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "falseBlockRateMetric": {
      "type": "object",
      "additionalProperties": true,
      "required": ["annotatedFalseBlocks", "totalBlocks", "ratio"],
      "properties": {
        "annotatedFalseBlocks": {
          "oneOf": [
            { "$ref": "#/$defs/nonNegativeInteger" },
            { "type": "null" }
          ]
        },
        "totalBlocks": { "$ref": "#/$defs/nonNegativeInteger" },
        "ratio": { "$ref": "#/$defs/ratioOrNull" },
        "annotationRequired": { "type": "boolean" }
      }
    },
    "collectibleCountMetricValue": {
      "oneOf": [
        { "$ref": "#/$defs/nonNegativeInteger" },
        { "enum": ["unknown", "not_collected"] }
      ]
    },
    "collectibleNumberMetricValue": {
      "oneOf": [
        { "$ref": "#/$defs/nonNegativeNumber" },
        { "enum": ["unknown", "not_collected"] }
      ]
    },
    "requiredCheckLatest": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "status": { "type": ["string", "null"] },
        "conclusion": { "type": ["string", "null"] },
        "workflowName": { "type": ["string", "null"] },
        "startedAt": { "type": ["string", "null"], "format": "date-time" },
        "completedAt": { "type": ["string", "null"], "format": "date-time" },
        "detailsUrl": { "type": ["string", "null"] },
        "headSha": { "type": ["string", "null"] }
      }
    },
    "requiredCheckStaleAttempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "sameHeadStale",
        "status",
        "conclusion",
        "workflowName",
        "startedAt",
        "completedAt",
        "detailsUrl",
        "headSha"
      ],
      "properties": {
        "classification": { "$ref": "#/$defs/nonEmptyString" },
        "sameHeadStale": { "type": "boolean" },
        "status": { "type": ["string", "null"] },
        "conclusion": { "type": ["string", "null"] },
        "workflowName": { "type": ["string", "null"] },
        "startedAt": { "type": ["string", "null"], "format": "date-time" },
        "completedAt": { "type": ["string", "null"], "format": "date-time" },
        "detailsUrl": { "type": ["string", "null"] },
        "headSha": { "type": ["string", "null"] }
      }
    },
    "ciRerunClassificationCountsMetric": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "total",
            "stale_cancelled",
            "superseded",
            "same_head_stale",
            "manual_rerun_required"
          ],
          "properties": {
            "total": { "$ref": "#/$defs/nonNegativeInteger" },
            "stale_cancelled": { "$ref": "#/$defs/nonNegativeInteger" },
            "superseded": { "$ref": "#/$defs/nonNegativeInteger" },
            "same_head_stale": { "$ref": "#/$defs/nonNegativeInteger" },
            "manual_rerun_required": { "$ref": "#/$defs/nonNegativeInteger" }
          }
        },
        { "enum": ["not_collected"] }
      ]
    },
    "requiredCheckEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "collected",
        "latest",
        "classification",
        "review_disposition",
        "attempts",
        "stale_or_superseded_failure_count",
        "stale_attempts",
        "stale_cancelled_count",
        "superseded_count",
        "same_head_stale_count"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "collected": { "type": "boolean" },
        "latest": {
          "oneOf": [
            { "$ref": "#/$defs/requiredCheckLatest" },
            { "type": "null" }
          ]
        },
        "classification": { "$ref": "#/$defs/nonEmptyString" },
        "review_disposition": { "$ref": "#/$defs/nonEmptyString" },
        "attempts": { "$ref": "#/$defs/nonNegativeInteger" },
        "stale_or_superseded_failure_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "stale_attempts": {
          "type": "array",
          "items": { "$ref": "#/$defs/requiredCheckStaleAttempt" }
        },
        "stale_cancelled_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "superseded_count": { "$ref": "#/$defs/nonNegativeInteger" },
        "same_head_stale_count": { "$ref": "#/$defs/nonNegativeInteger" }
      }
    },
    "requiredChecksMetric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "required", "summary"],
      "properties": {
        "source": { "$ref": "#/$defs/nonEmptyString" },
        "required": {
          "type": "array",
          "items": { "$ref": "#/$defs/requiredCheckEntry" }
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required_count",
            "collected_count",
            "success_count",
            "pending_count",
            "current_required_failure_count",
            "policy_semantic_failure_count",
            "operational_failure_count",
            "manual_rerun_required_count",
            "stale_or_superseded_failure_count",
            "stale_cancelled_count",
            "superseded_count",
            "same_head_stale_count",
            "semantic_blocking_failure_count",
            "operational_note_count"
          ],
          "properties": {
            "required_count": { "$ref": "#/$defs/nonNegativeInteger" },
            "collected_count": { "$ref": "#/$defs/nonNegativeInteger" },
            "success_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
            "pending_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
            "current_required_failure_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
            "policy_semantic_failure_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
            "operational_failure_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
            "manual_rerun_required_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
            "stale_or_superseded_failure_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
            "stale_cancelled_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
            "superseded_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
            "same_head_stale_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
            "semantic_blocking_failure_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
            "operational_note_count": { "$ref": "#/$defs/collectibleCountMetricValue" }
          }
        }
      }
    },
    "agentPrAssuranceProductMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_threads_total",
        "review_threads_unresolved_final",
        "required_checks",
        "scope_drift_finding_count",
        "missing_evidence_finding_count",
        "selected_high_risk_claim_count",
        "ci_rerun_count",
        "ci_rerun_classification_counts",
        "time_to_merge_minutes",
        "policy_gate_false_positive_count",
        "policy_gate_false_negative_count"
      ],
      "properties": {
        "review_threads_total": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "review_threads_unresolved_final": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "required_checks": { "$ref": "#/$defs/requiredChecksMetric" },
        "scope_drift_finding_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "missing_evidence_finding_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "selected_high_risk_claim_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "ci_rerun_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "ci_rerun_classification_counts": { "$ref": "#/$defs/ciRerunClassificationCountsMetric" },
        "time_to_merge_minutes": { "$ref": "#/$defs/collectibleNumberMetricValue" },
        "policy_gate_false_positive_count": { "$ref": "#/$defs/collectibleCountMetricValue" },
        "policy_gate_false_negative_count": { "$ref": "#/$defs/collectibleCountMetricValue" }
      }
    },
    "agentPrAssurancePullRequest": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": {
          "oneOf": [
            { "$ref": "#/$defs/nonEmptyString" },
            { "enum": ["unknown"] }
          ]
        },
        "number": {
          "oneOf": [
            { "$ref": "#/$defs/nonNegativeInteger" },
            { "enum": ["unknown"] }
          ]
        },
        "title": { "type": "string" },
        "url": { "type": ["string", "null"] },
        "state": { "type": "string" },
        "createdAt": { "type": ["string", "null"], "format": "date-time" },
        "reviewReadyAt": { "type": ["string", "null"], "format": "date-time" },
        "mergedAt": { "type": ["string", "null"], "format": "date-time" },
        "headRefOid": { "type": ["string", "null"] },
        "mergeStateStatus": { "type": ["string", "null"] }
      }
    },
    "collectionSources": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "reviewCompleteness": { "$ref": "#/$defs/nonEmptyString" },
        "producerSummaries": { "$ref": "#/$defs/artifactArray" },
        "boundaryMapSummaries": { "$ref": "#/$defs/artifactArray" },
        "assuranceProfiles": { "$ref": "#/$defs/artifactArray" },
        "claimEvidenceManifests": { "$ref": "#/$defs/artifactArray" },
        "policyGateSummaries": { "$ref": "#/$defs/artifactArray" }
      }
    },
    "agentPrAssuranceMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_coverage",
        "unresolved_claim_count",
        "waiver_count",
        "waiver_expiry_risk",
        "required_lane_compliance",
        "evidence_completeness",
        "agent_regression_signal",
        "blocked_to_merge_eligible_mttr",
        "false_block_rate"
      ],
      "properties": {
        "claim_coverage": { "$ref": "#/$defs/coverageMetric" },
        "unresolved_claim_count": { "$ref": "#/$defs/countMetric" },
        "waiver_count": { "$ref": "#/$defs/waiverCountMetric" },
        "waiver_expiry_risk": { "$ref": "#/$defs/waiverExpiryRiskMetric" },
        "required_lane_compliance": { "$ref": "#/$defs/laneComplianceMetric" },
        "evidence_completeness": { "$ref": "#/$defs/evidenceCompletenessMetric" },
        "agent_regression_signal": { "$ref": "#/$defs/agentRegressionSignalMetric" },
        "blocked_to_merge_eligible_mttr": { "$ref": "#/$defs/mttrMetric" },
        "false_block_rate": { "$ref": "#/$defs/falseBlockRateMetric" }
      }
    },
    "agentPrAssurance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["reportOnly", "metrics"],
      "properties": {
        "reportOnly": { "const": true },
        "generatedAt": { "type": "string", "format": "date-time" },
        "source": { "$ref": "#/$defs/nonEmptyString" },
        "pullRequest": { "$ref": "#/$defs/agentPrAssurancePullRequest" },
        "collectionSources": { "$ref": "#/$defs/collectionSources" },
        "metrics": { "$ref": "#/$defs/agentPrAssuranceMetrics" },
        "productMetrics": { "$ref": "#/$defs/agentPrAssuranceProductMetrics" },
        "limitations": { "$ref": "#/$defs/stringArray" },
        "summary": { "$ref": "#/$defs/nonEmptyString" }
      }
    }
  }
}
