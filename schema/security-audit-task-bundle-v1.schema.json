{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/security-audit-task-bundle-v1.schema.json",
  "title": "Security Audit Task Bundle v1",
  "description": "Deterministic proof-attempt audit tasks generated from security claims and a security code map. Tasks are prompt inputs for audit simulation and are not vulnerability findings.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "tasks",
    "summary",
    "provenance"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "security-audit-task-bundle/v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "path",
        "message"
      ],
      "properties": {
        "code": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "source": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "message": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "auditStatus": {
      "type": "string",
      "enum": [
        "ready",
        "blocked-no-candidate-location",
        "blocked-missing-code-map"
      ]
    },
    "candidateLocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "startLine",
        "endLine",
        "reason"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "startLine": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        },
        "symbol": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "reason": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "matchedTerms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      },
      "$comment": "Semantic validation enforces endLine >= startLine."
    },
    "proofAttemptPrompt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "map",
        "prove",
        "stressTest",
        "report"
      ],
      "properties": {
        "map": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "prove": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "stressTest": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "report": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "claimId",
        "claimStatement",
        "status",
        "candidateLocations",
        "scopeRefs",
        "proofAttemptPrompt",
        "warnings"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "claimId": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "claimStatement": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/auditStatus"
        },
        "candidateLocations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidateLocation"
          }
        },
        "scopeRefs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "proofAttemptPrompt": {
          "$ref": "#/$defs/proofAttemptPrompt"
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalTasks",
        "readyTasks",
        "blockedTasks",
        "totalCandidateLocations",
        "totalWarnings",
        "byStatus"
      ],
      "properties": {
        "totalTasks": {
          "type": "integer",
          "minimum": 0
        },
        "readyTasks": {
          "type": "integer",
          "minimum": 0
        },
        "blockedTasks": {
          "type": "integer",
          "minimum": 0
        },
        "totalCandidateLocations": {
          "type": "integer",
          "minimum": 0
        },
        "totalWarnings": {
          "type": "integer",
          "minimum": 0
        },
        "byStatus": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ready",
            "blockedNoCandidateLocation",
            "blockedMissingCodeMap"
          ],
          "properties": {
            "ready": {
              "type": "integer",
              "minimum": 0
            },
            "blockedNoCandidateLocation": {
              "type": "integer",
              "minimum": 0
            },
            "blockedMissingCodeMap": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "origin",
        "generator",
        "claims",
        "codeMap",
        "scope"
      ],
      "properties": {
        "origin": {
          "type": "string",
          "enum": [
            "deterministic",
            "fixture"
          ]
        },
        "generator": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "claims": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "codeMap": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "scope": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "version": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    }
  }
}

