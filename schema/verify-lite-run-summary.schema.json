{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/verify-lite-run-summary.schema.json",
  "title": "Verify Lite Run Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "timestamp",
    "metadata",
    "flags",
    "steps",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Semver identifier for this summary format.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "$ref": "https://ae-framework/schema/artifact-metadata.schema.json"
    },
    "flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "install",
        "noFrozen",
        "keepLintLog",
        "enforceLint",
        "runMutation"
      ],
      "properties": {
        "install": {
          "type": "string"
        },
        "noFrozen": {
          "type": "boolean"
        },
        "keepLintLog": {
          "type": "boolean"
        },
        "enforceLint": {
          "type": "boolean"
        },
        "runMutation": {
          "type": "boolean"
        }
      }
    },
    "steps": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success",
              "failure",
              "skipped",
              "pending",
              "unknown"
            ]
          },
          "notes": {
            "type": ["string", "null"]
          },
          "retried": {
            "type": "boolean"
          }
        }
      }
    },
    "traceability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "missingCount",
        "matrixPath",
        "notes"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "failure",
            "skipped",
            "pending",
            "unknown"
          ]
        },
        "missingCount": {
          "type": "integer",
          "minimum": 0
        },
        "matrixPath": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "notes": {
          "type": ["string", "null"]
        }
      }
    },
    "discoveryPack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "reason",
        "sourcePresent",
        "strictApproved",
        "failOn",
        "validateStatus",
        "compileStatus",
        "scannedFiles",
        "warningFiles",
        "failedFiles",
        "blockingOpenQuestions",
        "orphanApprovedRequirements",
        "orphanApprovedBusinessUseCases",
        "compileSelectedCount",
        "compileExcludedByStatusCount",
        "compileSkippedByTargetCount"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["report-only", "strict"]
        },
        "reason": {
          "type": ["string", "null"]
        },
        "sourcePresent": {
          "type": "boolean"
        },
        "strictApproved": {
          "type": "boolean"
        },
        "failOn": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "blocking-open-questions",
              "orphan-approved-requirements",
              "orphan-approved-business-use-cases"
            ]
          },
          "uniqueItems": true
        },
        "validateStatus": {
          "type": "string",
          "enum": ["pass", "warn", "fail", "skipped", "missing", "unknown"]
        },
        "compileStatus": {
          "type": "string",
          "enum": ["pass", "warn", "fail", "skipped", "missing", "unknown"]
        },
        "scannedFiles": {
          "type": "integer",
          "minimum": 0
        },
        "warningFiles": {
          "type": "integer",
          "minimum": 0
        },
        "failedFiles": {
          "type": "integer",
          "minimum": 0
        },
        "blockingOpenQuestions": {
          "type": "integer",
          "minimum": 0
        },
        "orphanApprovedRequirements": {
          "type": "integer",
          "minimum": 0
        },
        "orphanApprovedBusinessUseCases": {
          "type": "integer",
          "minimum": 0
        },
        "compileSelectedCount": {
          "type": "integer",
          "minimum": 0
        },
        "compileExcludedByStatusCount": {
          "type": "integer",
          "minimum": 0
        },
        "compileSkippedByTargetCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lintSummary",
        "lintLog",
        "mutationSummary",
        "mutationSurvivors",
        "conformanceSummary",
        "conformanceSummaryMarkdown"
      ],
      "properties": {
        "lintSummary": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "lintLog": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "mutationSummary": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "mutationSurvivors": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "contextPackReportJson": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "contextPackReportMarkdown": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "contextPackFunctorReportJson": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "contextPackFunctorReportMarkdown": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "contextPackNaturalTransformationReportJson": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "contextPackNaturalTransformationReportMarkdown": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "contextPackProductCoproductReportJson": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "contextPackProductCoproductReportMarkdown": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "contextPackPhase5ReportJson": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "contextPackPhase5ReportMarkdown": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "discoveryPackValidateReportJson": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "discoveryPackValidateReportMarkdown": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "discoveryPackCompileReportJson": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "discoveryPackCompileReportMarkdown": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "discoveryPackPlanSpec": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "conformanceSummary": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "conformanceSummaryMarkdown": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
