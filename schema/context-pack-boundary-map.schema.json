{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/context-pack-boundary-map.schema.json",
  "title": "Context Pack Boundary Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contextPackSources",
    "slices"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "context-pack-boundary-map/v1"
    },
    "contextPackSources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "slices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/slice"
      }
    }
  },
  "$defs": {
    "boundaryRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "refId"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "object",
            "morphism",
            "diagram",
            "acceptance-test",
            "forbidden-change"
          ]
        },
        "refId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "context-pack",
            "slice"
          ]
        },
        "sliceId": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "slice"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "sliceId"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "context-pack"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "not": {
              "required": [
                "sliceId"
              ]
            }
          }
        }
      ]
    },
    "consumedRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "refId",
        "upstream"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "object",
            "morphism",
            "diagram",
            "acceptance-test",
            "forbidden-change"
          ]
        },
        "refId": {
          "type": "string",
          "minLength": 1
        },
        "upstream": {
          "$ref": "#/$defs/upstream"
        }
      }
    },
    "slice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "produces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/boundaryRef"
          }
        },
        "consumes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/consumedRef"
          }
        }
      },
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "produces"
              ]
            },
            {
              "required": [
                "consumes"
              ]
            }
          ]
        }
      ]
    }
  }
}
