{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/symbol-index-v1.schema.json",
  "title": "Symbol Index v1",
  "description": "Language-neutral symbol index consumed as optional deterministic input for security claim-to-code mapping. This contract records symbol metadata only; it is not a call graph or dataflow proof.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "symbols",
    "summary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "symbol-index/v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "symbols": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/symbol"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "symbol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "language",
        "kind",
        "name",
        "path",
        "startLine",
        "endLine"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "language": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "kind": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "startLine": {
          "type": "integer",
          "minimum": 1
        },
        "endLine": {
          "type": "integer",
          "minimum": 1
        },
        "exported": {
          "type": "boolean"
        },
        "signature": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "doc": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalSymbols",
        "byLanguage"
      ],
      "properties": {
        "totalSymbols": {
          "type": "integer",
          "minimum": 0
        },
        "byLanguage": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
