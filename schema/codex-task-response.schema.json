{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://itdojp.github.io/ae-framework/schema/codex-task-response.schema.json",
  "title": "CodexTaskResponse",
  "type": "object",
  "required": [
    "summary",
    "analysis",
    "recommendations",
    "nextActions",
    "warnings",
    "shouldBlockProgress"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "analysis": {
      "type": "string"
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "shouldBlockProgress": {
      "type": "boolean"
    },
    "blockingReason": {
      "type": "string",
      "minLength": 1
    },
    "requiredHumanInput": {
      "type": "string",
      "minLength": 1
    },
    "formal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scaffold", "modelChecking"],
      "properties": {
        "scaffold": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "artifactStatus", "validationStatus", "materializationStatus", "artifacts"],
          "properties": {
            "status": { "const": "generated" },
            "artifactStatus": { "const": "draft" },
            "validationStatus": {
              "enum": ["valid", "invalid", "pending"]
            },
            "materializationStatus": {
              "enum": ["written", "partial", "failed"]
            },
            "artifacts": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "allOf": [
                { "contains": { "properties": { "kind": { "const": "tla" } }, "required": ["kind"] }, "minContains": 1, "maxContains": 1 },
                { "contains": { "properties": { "kind": { "const": "openapi" } }, "required": ["kind"] }, "minContains": 1, "maxContains": 1 }
              ],
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "status"],
                "properties": {
                  "kind": { "enum": ["tla", "openapi"] },
                  "status": { "enum": ["written", "failed"] },
                  "path": { "type": "string", "minLength": 1 },
                  "message": { "type": "string", "minLength": 1, "maxLength": 160 }
                },
                "allOf": [
                  {
                    "if": { "properties": { "status": { "const": "written" } }, "required": ["status"] },
                    "then": { "required": ["path"], "not": { "required": ["message"] } }
                  },
                  {
                    "if": { "properties": { "status": { "const": "failed" } }, "required": ["status"] },
                    "then": { "required": ["message"], "not": { "required": ["path"] } }
                  }
                ]
              }
            },
            "artifactPath": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "modelChecking": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "evidenceArtifact", "runnerCommands"],
          "properties": {
            "status": { "const": "not-run" },
            "evidenceArtifact": { "type": "null" },
            "runnerCommands": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "shouldBlockProgress": {
            "const": false
          }
        }
      },
      "then": {
        "properties": {
          "nextActions": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "shouldBlockProgress": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "nextActions": {
            "minItems": 1
          },
          "warnings": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
