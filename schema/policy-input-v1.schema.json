{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/policy-input-v1.schema.json",
  "title": "ae-policy-input-v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "contractId": {
      "type": "string",
      "const": "policy-input.v1"
    },
    "generatedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "prNumber": {
      "type": "integer",
      "minimum": 1
    },
    "policyPath": {
      "type": "string",
      "minLength": 1
    },
    "policy": {
      "$ref": "#/$defs/policy"
    },
    "pullRequest": {
      "$ref": "#/$defs/pullRequest"
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "reviews": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/review"
      }
    },
    "statusRollup": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/statusItem"
      }
    },
    "config": {
      "$ref": "#/$defs/config"
    },
    "assurance": {
      "$ref": "#/$defs/assuranceInput"
    }
  },
  "required": [
    "schemaVersion",
    "contractId",
    "generatedAtUtc",
    "repository",
    "prNumber",
    "policyPath",
    "policy",
    "pullRequest",
    "changedFiles",
    "reviews",
    "statusRollup",
    "config"
  ],
  "$defs": {
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "labels": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "risk": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "low": {
                  "type": "string",
                  "minLength": 1
                },
                "high": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "low",
                "high"
              ]
            },
            "optionalGates": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          },
          "required": [
            "risk",
            "optionalGates"
          ]
        },
        "requiredChecks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "highRisk": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minHumanApprovals": {
              "type": "integer",
              "minimum": 0
            },
            "requirePolicyLabels": {
              "type": "boolean"
            },
            "requirePlanArtifact": {
              "type": "boolean"
            },
            "failWhenRequiredGateIsPending": {
              "type": "boolean"
            }
          },
          "required": [
            "minHumanApprovals",
            "requirePolicyLabels",
            "requirePlanArtifact",
            "failWhenRequiredGateIsPending"
          ]
        },
        "assuranceEscalation": {
          "$ref": "#/$defs/assuranceEscalation"
        },
        "classification": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "highRiskPaths": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "forceHighRiskWhen": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          },
          "required": [
            "highRiskPaths",
            "forceHighRiskWhen"
          ]
        },
        "labelRequirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/labelRequirement"
          }
        },
        "gateChecks": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/gateCheckMapping"
          }
        }
      },
      "required": [
        "labels",
        "requiredChecks",
        "highRisk",
        "assuranceEscalation",
        "classification",
        "labelRequirements",
        "gateChecks"
      ]
    },
    "assuranceEscalation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultMode": {
          "type": "string",
          "minLength": 1
        },
        "waiverRequiredFields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "lanes": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/assuranceEscalationLane"
          }
        },
        "findingClasses": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "required": [
        "defaultMode",
        "waiverRequiredFields",
        "lanes",
        "findingClasses"
      ]
    },
    "assuranceEscalationLane": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trigger": {
          "type": [
            "string",
            "null"
          ]
        },
        "triggerLabels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "requiredResponse": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "required": [
        "trigger",
        "triggerLabels",
        "decision",
        "requiredResponse"
      ]
    },
    "labelRequirement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "whenAnyChanged": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "requireLabels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "required": [
        "id",
        "whenAnyChanged",
        "requireLabels"
      ]
    },
    "gateCheckMapping": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "patterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "required": [
        "patterns"
      ]
    },
    "pullRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "body": {
          "type": "string"
        }
      },
      "required": [
        "number",
        "labels",
        "body"
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "state": {
          "type": "string",
          "minLength": 1
        },
        "submittedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "user": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "login": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "login",
            "type"
          ]
        }
      },
      "required": [
        "id",
        "state",
        "submittedAt",
        "user"
      ]
    },
    "statusItem": {
      "oneOf": [
        {
          "$ref": "#/$defs/checkRun"
        },
        {
          "$ref": "#/$defs/statusContext"
        }
      ]
    },
    "checkRun": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "__typename": {
          "type": "string",
          "const": "CheckRun"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "conclusion": {
          "type": [
            "string",
            "null"
          ]
        },
        "workflowName": {
          "type": "string"
        },
        "startedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "completedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "required": [
        "__typename",
        "name",
        "status",
        "conclusion"
      ]
    },
    "statusContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "__typename": {
          "type": "string",
          "const": "StatusContext"
        },
        "context": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "__typename",
        "context",
        "state"
      ]
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reviewTopology": {
          "type": [
            "string",
            "null"
          ]
        },
        "approvalOverride": {
          "type": [
            "string",
            "null"
          ]
        },
        "assuranceMode": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "report-only",
            "strict",
            null
          ]
        }
      },
      "required": [
        "reviewTopology",
        "approvalOverride"
      ]
    },
    "assuranceInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "present",
        "schemaVersion",
        "generatedAt",
        "summary",
        "claims",
        "warnings",
        "errors"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "present": {
          "type": "boolean"
        },
        "schemaVersion": {
          "type": [
            "string",
            "null"
          ]
        },
        "generatedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "provenance": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true,
          "required": [
            "path",
            "present",
            "trusted",
            "schemaVersion",
            "generatedAt"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "present": {
              "type": "boolean"
            },
            "trusted": {
              "type": "boolean"
            },
            "schemaVersion": {
              "type": [
                "string",
                "null"
              ]
            },
            "generatedAt": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            }
          }
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "totalClaims",
            "fullySupported",
            "partiallySupported",
            "waived",
            "unresolved"
          ],
          "properties": {
            "totalClaims": {
              "type": "integer",
              "minimum": 0
            },
            "fullySupported": {
              "type": "integer",
              "minimum": 0
            },
            "partiallySupported": {
              "type": "integer",
              "minimum": 0
            },
            "waived": {
              "type": "integer",
              "minimum": 0
            },
            "unresolved": {
              "type": "integer",
              "minimum": 0
            },
            "security": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "claims",
                "findings",
                "reviews",
                "candidate",
                "needsHumanReview",
                "confirmed",
                "rejected",
                "waived",
                "outOfScope",
                "highOrCriticalOpen"
              ],
              "properties": {
                "claims": {
                  "type": "integer",
                  "minimum": 0
                },
                "findings": {
                  "type": "integer",
                  "minimum": 0
                },
                "reviews": {
                  "type": "integer",
                  "minimum": 0
                },
                "candidate": {
                  "type": "integer",
                  "minimum": 0
                },
                "needsHumanReview": {
                  "type": "integer",
                  "minimum": 0
                },
                "confirmed": {
                  "type": "integer",
                  "minimum": 0
                },
                "rejected": {
                  "type": "integer",
                  "minimum": 0
                },
                "waived": {
                  "type": "integer",
                  "minimum": 0
                },
                "outOfScope": {
                  "type": "integer",
                  "minimum": 0
                },
                "highOrCriticalOpen": {
                  "type": "integer",
                  "minimum": 0
                },
                "assumptionValidationRequired": {
                  "type": "integer",
                  "minimum": 0
                },
                "assumptionResidualRisk": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        },
        "claims": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "claimId",
              "result",
              "status",
              "evidenceRefs",
              "missingEvidenceRefs",
              "waiverRefs",
              "waivers"
            ],
            "properties": {
              "claimId": {
                "type": "string",
                "minLength": 1
              },
              "result": {
                "type": "string",
                "enum": [
                  "pass",
                  "waived",
                  "report-only",
                  "block"
                ]
              },
              "status": {
                "type": "string",
                "minLength": 1
              },
              "evidenceRefs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "missingEvidenceRefs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "waiverRefs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "waivers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "id",
                    "status"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "sourceArtifactId": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "status": {
                      "type": "string",
                      "enum": [
                        "active",
                        "expiringSoon",
                        "expired",
                        "orphan",
                        "unknown"
                      ]
                    },
                    "owner": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "expires": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "format": "date"
                    },
                    "reason": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
