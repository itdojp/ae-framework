{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/plan-artifact.schema.json",
  "title": "Plan Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contractId",
    "generatedAt",
    "source",
    "goal",
    "scope",
    "risk",
    "assumptions",
    "filesExpectedToChange",
    "verificationPlan",
    "rollbackPlan",
    "requiredHumanInput"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "plan-artifact/v1"
    },
    "contractId": {
      "type": "string",
      "const": "plan-artifact.v1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "risk": {
      "$ref": "#/$defs/risk"
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/namedText"
      }
    },
    "filesExpectedToChange": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verificationPlan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/verificationStep"
      }
    },
    "rollbackPlan": {
      "type": "string",
      "minLength": 1
    },
    "requiredHumanInput": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "prNumber",
        "baseRef",
        "headRef"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "prNumber": {
          "type": "integer",
          "minimum": 1
        },
        "baseRef": {
          "type": "string",
          "minLength": 1
        },
        "headRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected",
        "requiresHumanApproval",
        "minHumanApprovals"
      ],
      "properties": {
        "selected": {
          "type": "string",
          "enum": ["risk:low", "risk:high"]
        },
        "requiresHumanApproval": {
          "type": "boolean"
        },
        "minHumanApprovals": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "namedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "verificationStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "command"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "expectedEvidence": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
