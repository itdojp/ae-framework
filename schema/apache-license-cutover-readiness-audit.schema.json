{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/apache-license-cutover-readiness-audit.schema.json",
  "title": "Apache License Cutover Readiness Audit v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "inputs",
    "summary",
    "readiness"
  ],
  "properties": {
    "schemaVersion": { "const": "apache-license-cutover-readiness-audit/v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopeAuditPath",
        "conditionalAuditPath",
        "noticeReadinessAuditPath",
        "contributorReadinessAuditPath",
        "repositoryLicense",
        "packageLicenseField"
      ],
      "properties": {
        "scopeAuditPath": { "type": "string", "minLength": 1 },
        "conditionalAuditPath": { "type": "string", "minLength": 1 },
        "noticeReadinessAuditPath": { "type": "string", "minLength": 1 },
        "contributorReadinessAuditPath": { "type": "string", "minLength": 1 },
        "repositoryLicense": { "type": ["string", "null"] },
        "packageLicenseField": { "type": ["string", "null"] }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blockerCount",
        "humanReviewRequired",
        "nestedNoticeFilesCount",
        "unclassifiedConditionalFilesCount",
        "contributorHumanLikeCount",
        "contributorBotLikeCount",
        "contributorNoreplyCount"
      ],
      "properties": {
        "blockerCount": { "type": "integer", "minimum": 0 },
        "humanReviewRequired": { "type": "boolean" },
        "nestedNoticeFilesCount": { "type": "integer", "minimum": 0 },
        "unclassifiedConditionalFilesCount": { "type": "integer", "minimum": 0 },
        "contributorHumanLikeCount": { "type": "integer", "minimum": 0 },
        "contributorBotLikeCount": { "type": "integer", "minimum": 0 },
        "contributorNoreplyCount": { "type": "integer", "minimum": 0 }
      }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "recommendedAction",
        "blockers",
        "humanReviewReasons",
        "cutoverPrerequisites"
      ],
      "properties": {
        "status": {
          "enum": ["blocked", "human-review-required", "ready"]
        },
        "recommendedAction": {
          "enum": ["resolve-blockers", "legal-review", "prepare-cutover-pr"]
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "reason"],
            "properties": {
              "code": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        },
        "humanReviewReasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 0
        },
        "cutoverPrerequisites": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      }
    }
  }
,
  "allOf": [
    {
      "if": {
        "properties": {
          "readiness": {
            "properties": {
              "status": { "const": "ready" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "readiness": {
            "properties": {
              "humanReviewReasons": { "maxItems": 0 }
            }
          }
        }
      },
      "else": {
        "properties": {
          "readiness": {
            "properties": {
              "humanReviewReasons": { "minItems": 1 }
            }
          }
        }
      }
    }
  ]

}
