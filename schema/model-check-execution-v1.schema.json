{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/model-check-execution-v1.schema.json",
  "title": "Model Check Execution Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "artifactStatus", "status", "ok", "generatedAtUtc", "producer", "tlc", "alloy"],
  "properties": {
    "schemaVersion": { "const": "model-check-report/v1" },
    "artifactStatus": { "const": "execution-report" },
    "status": { "enum": ["executed", "failed", "tool-error", "not-run"] },
    "ok": { "type": ["boolean", "null"] },
    "generatedAtUtc": { "type": "string", "format": "date-time" },
    "producer": { "const": "scripts/verify/run-model-checks.mjs" },
    "tlc": { "$ref": "#/$defs/tlcBackend" },
    "alloy": { "$ref": "#/$defs/alloyBackend" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "executed" } }, "required": ["status"] },
      "then": {
        "allOf": [
          { "properties": { "ok": { "const": true } } },
          {
            "properties": {
              "tlc": {
                "properties": {
                  "results": {
                    "items": {
                      "properties": {
                        "ok": { "const": true },
                        "executionStatus": { "const": "executed" },
                        "evidence": { "properties": { "result": { "properties": { "outcome": { "const": "pass" } } } } }
                      }
                    }
                  },
                  "errors": { "maxItems": 0 }
                }
              },
              "alloy": {
                "properties": {
                  "results": {
                    "items": {
                      "properties": {
                        "ok": { "const": true },
                        "executionStatus": { "const": "executed" },
                        "evidence": { "properties": { "result": { "properties": { "outcome": { "const": "pass" } } } } }
                      }
                    }
                  },
                  "errors": { "maxItems": 0 }
                }
              }
            }
          },
          {
            "anyOf": [
              { "properties": { "tlc": { "properties": { "results": { "minItems": 1 } } } } },
              { "properties": { "alloy": { "properties": { "results": { "minItems": 1 } } } } }
            ]
          }
        ]
      }
    },
    {
      "if": { "properties": { "status": { "const": "failed" } }, "required": ["status"] },
      "then": { "properties": { "ok": { "const": false } } }
    },
    {
      "if": { "properties": { "status": { "enum": ["tool-error", "not-run"] } }, "required": ["status"] },
      "then": { "properties": { "ok": { "type": "null" } } }
    },
    {
      "if": { "properties": { "status": { "const": "not-run" } }, "required": ["status"] },
      "then": {
        "properties": {
          "tlc": { "properties": { "results": { "maxItems": 0 }, "errors": { "maxItems": 0 } } },
          "alloy": { "properties": { "results": { "maxItems": 0 }, "errors": { "maxItems": 0 } } }
        }
      }
    },
    {
      "if": { "properties": { "status": { "const": "tool-error" } }, "required": ["status"] },
      "then": {
        "anyOf": [
          { "properties": { "tlc": { "properties": { "errors": { "minItems": 1 } } } } },
          { "properties": { "alloy": { "properties": { "errors": { "minItems": 1 } } } } },
          { "properties": { "tlc": { "properties": { "results": { "contains": { "properties": { "executionStatus": { "const": "tool-error" } }, "required": ["executionStatus"] } } } } } },
          { "properties": { "alloy": { "properties": { "results": { "contains": { "properties": { "executionStatus": { "const": "tool-error" } }, "required": ["executionStatus"] } } } } } }
        ]
      }
    }
  ],
  "$defs": {
    "backendBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["results", "skipped", "errors"],
      "properties": {
        "results": { "type": "array" },
        "skipped": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["file", "error"],
            "properties": {
              "file": { "type": "string", "minLength": 1 },
              "error": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "tlcBackend": {
      "allOf": [
        { "$ref": "#/$defs/backendBase" },
        { "properties": { "results": { "type": "array", "items": { "$ref": "#/$defs/tlcResult" } } } }
      ]
    },
    "alloyBackend": {
      "allOf": [
        { "$ref": "#/$defs/backendBase" },
        { "properties": { "results": { "type": "array", "items": { "$ref": "#/$defs/alloyResult" } } } }
      ]
    },
    "tlcResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module", "ok", "code", "log", "config", "executionStatus", "evidence"],
      "properties": {
        "module": { "type": "string", "minLength": 1 },
        "ok": { "type": "boolean" },
        "code": { "type": ["integer", "null"] },
        "log": { "type": "string", "minLength": 1 },
        "config": { "type": "string", "minLength": 1 },
        "executionStatus": { "enum": ["executed", "tool-error", "timeout"] },
        "evidence": { "$ref": "#/$defs/executionEvidence" }
      }
    },
    "alloyResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "ok", "code", "signal", "timeout", "log", "executionStatus", "evidence"],
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "ok": { "type": "boolean" },
        "code": { "type": ["integer", "null"] },
        "signal": { "type": ["string", "null"] },
        "timeout": { "type": "boolean" },
        "log": { "type": "string", "minLength": 1 },
        "executionStatus": { "enum": ["executed", "tool-error", "timeout"] },
        "evidence": { "$ref": "#/$defs/executionEvidence" }
      }
    },
    "executionEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "input", "result", "scope", "assumptions"],
      "properties": {
        "tool": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "artifactPath", "artifactSha256"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "artifactPath": { "type": "string", "minLength": 1 },
            "artifactSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["specification", "configuration"],
          "properties": {
            "specification": { "type": "string", "minLength": 1 },
            "configuration": { "type": ["string", "null"] }
          }
        },
        "result": {
          "type": "object",
          "additionalProperties": false,
          "required": ["outcome", "exitCode", "log"],
          "properties": {
            "outcome": { "enum": ["pass", "fail", "timeout", "tool-error"] },
            "exitCode": { "type": ["integer", "null"] },
            "signal": { "type": ["string", "null"] },
            "error": { "type": "string", "minLength": 1 },
            "log": { "type": "string", "minLength": 1 }
          }
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "identifier", "properties"],
          "properties": {
            "kind": { "enum": ["tla-module", "alloy-model"] },
            "identifier": { "type": "string", "minLength": 1 },
            "properties": { "type": "string", "minLength": 1 }
          }
        },
        "assumptions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
