{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ae-framework/schema/publication-evidence-v1.schema.json",
  "title": "ae-framework publication evidence manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "repository", "asOf", "surfaces"],
  "properties": {
    "schemaVersion": { "const": "publication-evidence/v1" },
    "repository": { "const": "itdojp/ae-framework" },
    "asOf": { "type": "string", "format": "date-time" },
    "surfaces": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mainBranchProtection", "coreNpmPackage", "assuranceGateMarketplace"],
      "properties": {
        "mainBranchProtection": { "$ref": "#/$defs/mainBranchProtectionSurface" },
        "coreNpmPackage": { "$ref": "#/$defs/npmSurface" },
        "assuranceGateMarketplace": { "$ref": "#/$defs/marketplaceSurface" }
      }
    }
  },
  "$defs": {
    "state": {
      "type": "string",
      "enum": ["prepared", "blocked", "live", "withdrawn"]
    },
    "uri": { "type": "string", "format": "uri", "pattern": "^https://" },
    "blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "mainBranchProtectionSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "branch", "desiredContexts", "evidence", "blockers"],
      "properties": {
        "state": { "$ref": "#/$defs/state" },
        "branch": { "const": "main" },
        "desiredContexts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "observedAt": { "type": "string", "format": "date-time" },
            "verifier": { "type": "string", "minLength": 1 },
            "observedContexts": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "fetchUrl": { "$ref": "#/$defs/uri" },
            "fetchStatus": { "enum": ["success", "failure"] },
            "applyWorkflowRunUrl": { "$ref": "#/$defs/uri" },
            "applyStatus": { "enum": ["success", "failure"] }
          }
        },
        "blockers": { "$ref": "#/$defs/blockers" }
      }
    },
    "npmSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "package", "expectedVersion", "evidence", "blockers"],
      "properties": {
        "state": { "$ref": "#/$defs/state" },
        "package": { "const": "@ae-framework/core" },
        "expectedVersion": { "type": "string", "pattern": "^0\\.1\\.[0-9]+$" },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "verifiedAt": { "type": "string", "format": "date-time" },
            "verifier": { "type": "string", "minLength": 1 },
            "registryUrl": { "$ref": "#/$defs/uri" },
            "registryVersion": { "type": "string", "minLength": 1 },
            "publishWorkflowRunUrl": { "$ref": "#/$defs/uri" },
            "publishWorkflowMode": {
              "enum": ["preflight", "bootstrap-token", "trusted-publisher"]
            },
            "publishWorkflowStatus": { "enum": ["success", "failure"] },
            "provenanceUrl": { "$ref": "#/$defs/uri" },
            "cleanInstallImportEvidenceUrl": { "$ref": "#/$defs/uri" }
          }
        },
        "blockers": { "$ref": "#/$defs/blockers" }
      }
    },
    "marketplaceSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "actionRef", "immutableTag", "movingMajorTag", "evidence", "blockers"],
      "properties": {
        "state": { "$ref": "#/$defs/state" },
        "actionRef": { "type": "string", "pattern": "^itdojp/ae-framework@" },
        "immutableTag": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "movingMajorTag": { "type": "string", "pattern": "^v[0-9]+$" },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "verifiedAt": { "type": "string", "format": "date-time" },
            "verifier": { "type": "string", "minLength": 1 },
            "listingUrl": { "$ref": "#/$defs/uri" },
            "releaseNoteUrl": { "$ref": "#/$defs/uri" },
            "externalPathResolutionUrl": { "$ref": "#/$defs/uri" },
            "externalPathResolutionStatus": { "enum": ["success", "failure"] }
          }
        },
        "blockers": { "$ref": "#/$defs/blockers" }
      }
    }
  }
}
