{
  "name": "@ae-framework/core",
  "version": "0.1.0",
  "description": "Standalone minimal assurance core for ae-framework deploy-time profiles.",
  "license": "Apache-2.0",
  "keywords": [
    "assurance",
    "policy-gate",
    "github-actions",
    "software-supply-chain",
    "agentic-sdlc",
    "ai-code-review",
    "formal-methods",
    "json-schema"
  ],
  "homepage": "https://github.com/itdojp/ae-framework#readme",
  "bugs": {
    "url": "https://github.com/itdojp/ae-framework/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itdojp/ae-framework.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "PUBLISHING.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "check:no-src-imports": "node scripts/check-no-src-imports.mjs",
    "prepack": "pnpm run build && pnpm run check:no-src-imports"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^2.1.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.4",
    "vitest": "^3.2.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.11 <23"
  }
}
